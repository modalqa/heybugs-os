# Generic provider switch:
# openai-compatible | openrouter | gemini | claude | ollama | mock
HEYBUGS_AI_PROVIDER=openai-compatible

# Optional universal key used by os-heybugs AI clients.
# Needed only for AI features: prompt-to-feature and AI selector healing.
# Not required for regular deterministic .feature execution.
# You can also use provider-specific keys below.
HEYBUGS_AI_API_KEY=

# Optional provider-specific keys (fallback if HEYBUGS_AI_API_KEY is empty)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Endpoint and model (can be overridden per provider)
HEYBUGS_AI_API_BASE_URL=https://api.openai.com/v1
HEYBUGS_AI_MODEL=gpt-4o-mini

# Optional metadata (mainly for OpenRouter/Claude)
HEYBUGS_APP_NAME=os-heybugs
HEYBUGS_APP_URL=https://github.com/heybugs/os-heybugs
HEYBUGS_ANTHROPIC_VERSION=2023-06-01

# Runtime behavior
HEYBUGS_AUTO_HEAL_SELECTORS=true
HEYBUGS_PROMPT_TO_AUTOMATION=true